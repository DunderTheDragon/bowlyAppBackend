# Skopiuj ten plik jako .env i uzupełnij wartości przed uruchomieniem:
#   cp .env.example .env

# PostgreSQL (kontener db) — backend używa tych samych wartości (compose.yaml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bowly_db

# JDBC URL (w Dockerze hostem jest nazwa serwisu "db")
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/bowly_db

# JWT — wymagany, min. 32 znaki (HS256)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRATION_MS=86400000

# Port HTTP backendu (domyślnie 8742 — celowo inny niż typowe 8080)
SERVER_PORT=8742

# Hasło instancji — wymagane przy rejestracji (chroni przed botami na publicznym backendzie)
REGISTRATION_SECRET=change_me_registration_secret

# Hasła ze znakami specjalnymi (!, $, #) owiń w cudzysłowy, np.:
# POSTGRES_PASSWORD="TwojeHaslo123!"
